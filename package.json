{
  "name": "ternimal",
  "version": "1.0.0",
  "description": "Standalone terminal emulator built with xterm.js + node-pty (based on VS Code terminal architecture)",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "webpack --config webpack.main.config.js && webpack --config webpack.renderer.config.js",
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "start": "npm run build && electron .",
    "dev": "webpack --config webpack.main.config.js && webpack --config webpack.renderer.config.js && electron .",
    "rebuild": "electron-rebuild",
    "pack": "npm run build && electron-builder --win",
    "postinstall": ""
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "png-to-ico": "^3.0.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0"
  },
  "build": {
    "appId": "com.ternimal.app",
    "productName": "Ternimal",
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "node_modules/node-pty/**/*"
    ]
  }
}
